DEBUG=True
SECRET_KEY=change-me-in-production

DB_NAME=kds_db
DB_USER=kds_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

REDIS_HOST=localhost

# Licence (§licence) — laisser vide sur une installation cliente normale.
# EST_SERVEUR_MAITRE=True uniquement sur le serveur central qui héberge
# LicenceClient (ex: le VPS maître) ; une installation cliente renseigne
# plutôt LICENCE_MASTER_URL + LICENCE_IDENTIFIANT + LICENCE_CLE_API (fournis
# par LicenceClient.identifiant / .cle_api créés côté maître, cf. Django
# admin) pour que `manage.py verifier_licence` puisse pointer périodiquement.
EST_SERVEUR_MAITRE=False
LICENCE_MASTER_URL=
LICENCE_IDENTIFIANT=
LICENCE_CLE_API=

# §mise à jour client — n'a de sens que si EST_SERVEUR_MAITRE=True. Dossier
# où `scripts/publier-maj.sh` dépose les images publiées
# (kds-images-<version>.tar + LATEST_VERSION), servies via
# LicenceTelechargerVersionView. Laisser vide sur une installation cliente.
CLIENT_PACKAGES_DIR=
