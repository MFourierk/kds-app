# Python
venv/
__pycache__/
*.pyc
*.pyo
db.sqlite3

# Secrets / environnement local
.env

# Généré côté serveur — jamais versionné, régénéré à chaque déploiement
/staticfiles/
/media/

# Frontend
frontend/node_modules/
# frontend/dist/ est volontairement VERSIONNÉ (pas de Node.js sur le VPS de
# prod — le build est fait en local avant chaque commit/push, cf. DEPLOY.md).
# frontend/dist-client-package/ ne l'est PAS : profil de build distinct
# (URLs relatives, cf. build-client-package.sh) uniquement consommé par
# Dockerfile.frontend au moment de construire le paquet client, jamais
# servi tel quel par le VPS.
frontend/dist-client-package/

# Outils locaux (agent, IDE) — jamais pertinents côté serveur
.claude/
.test-driver/
.vscode/

# Artefacts du paquet d'installation client (images Docker, tar.gz) —
# générés par scripts/build-client-package.sh, jamais versionnés.
dist-client-package/

# OS
.DS_Store
Thumbs.db
