# Gabarit consommé par install.sh (substitution par sed) — ne pas éditer à
# la main pendant l'installation, laisser le script le faire.
# La version (KDS_VERSION, en bas de ce fichier) est déjà résolue par
# build-client-package.sh au moment où le paquet est construit — jamais
# laissée à deviner sur place.

DEBUG=False
SECRET_KEY=__SECRET_KEY__

# Pas de domaine public sur un réseau local client — HTTP simple, jamais de
# TLS possible ici (cf. config/settings.py, USE_HTTPS_REVERSE_PROXY).
USE_HTTPS_REVERSE_PROXY=False
ALLOWED_HOSTS=__ALLOWED_HOSTS__
CORS_ALLOWED_ORIGINS=__CORS_ALLOWED_ORIGINS__

DB_NAME=kds_db
DB_USER=kds_user
DB_PASSWORD=__DB_PASSWORD__
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis

# Licence (§licence) — cette installation est un CLIENT, jamais le maître.
EST_SERVEUR_MAITRE=False
LICENCE_MASTER_URL=__LICENCE_MASTER_URL__
LICENCE_IDENTIFIANT=__LICENCE_IDENTIFIANT__
LICENCE_CLE_API=__LICENCE_CLE_API__

# Consommé par le conteneur frontend (nginx), pas par Django — cf.
# deploy/client-package/40-generate-env-config.sh.
TENANT_SLUG=__TENANT_SLUG__

KDS_VERSION=__KDS_VERSION__
